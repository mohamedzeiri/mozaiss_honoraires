<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <record id="paperformat_note_honoraire" model="report.paperformat">
        <field name="name">Note Honoraire A4</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="page_height">0</field>
        <field name="page_width">0</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">10</field>
        <field name="margin_bottom">10</field>
        <field name="margin_left">10</field>
        <field name="margin_right">10</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>

    
    <record id="action_report_note_honoraire" model="ir.actions.report">
        <field name="name">Note d'Honoraire</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">mozaiss_honoraires.report_note_honoraire_template</field>
        <field name="report_file">mozaiss_honoraires.report_note_honoraire_template</field>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="mozaiss_honoraires.paperformat_note_honoraire"/>
    </record>
</odoo>
